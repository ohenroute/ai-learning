# Drupal PostgreSQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=drupal_site
DB_USER=
DB_PASSWORD=

# ContentStack API
CONTENTSTACK_API_KEY=
CONTENTSTACK_MANAGEMENT_TOKEN=
CONTENTSTACK_BASE_URL=https://api.contentstack.io/v3

# Migration Settings
DRUPAL_FILES_PATH=web/sites/default/files
# ^ Absolute path to Drupal's public files directory (e.g., /var/www/html/web/sites/default/files)
RATE_LIMIT_DELAY=0.15
# ^ Seconds between API calls (ContentStack allows 10 req/sec)
